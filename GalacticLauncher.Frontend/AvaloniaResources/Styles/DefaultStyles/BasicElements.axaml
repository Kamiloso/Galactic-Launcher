<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--StackPanel-->
	<Style Selector="StackPanel PathIcon">
		<Setter Property="Width" Value="15"/>
		<Setter Property="Height" Value="15"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Margin" Value="0,0,0,2"/>
	</Style>
	
	
	<!--TextBox-->
	<Style Selector="TextBox">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="VerticalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="CornerRadius" Value="20"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontFamily" Value="{DynamicResource Roboto}"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="Margin" Value="0,0,0,0"/>
		<Style.Resources>
			<SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
			<SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
		</Style.Resources>
	</Style>
	
	

	<!--Border-->
	<Style Selector="Border">
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="CornerRadius" Value="20"/>
	</Style>


	<!--Button-->
	<Style Selector="Button">

		<Setter Property="Foreground" Value="{StaticResource LightBlue}"/>
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalContentAlignment" Value="Left"/>
		<Setter Property="Padding" Value="30,10,0,10"/>
	</Style>

	<Style Selector="Button PathIcon">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="Margin" Value="0,0,0,2"/>
	</Style>

	<!-- Progress Bar-->
	<Style Selector="ProgressBar">
		<Setter Property="Background" Value="#202020"/>
		<Setter Property="Foreground" Value="{DynamicResource GalaxyGradient}"/>
	</Style>

	<Style Selector="ProgressBar /template/ Border#PART_Indicator">
		<Setter Property="Background" Value="{DynamicResource GalaxyGradient}"/>
		<Setter Property="CornerRadius" Value="3"/>
	</Style>

</Styles>
