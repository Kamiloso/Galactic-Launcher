<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--TextBox Galaxy Style-->
	<Style Selector="TextBox.TagAddTextBox">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="MinHeight" Value="30"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
		<Setter Property="AcceptsReturn" Value="True"/>

		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="VerticalAlignment" Value="Stretch"/>
		<Setter Property="HorizontalAlignment" Value="Stretch"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="CornerRadius" Value="20"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontFamily" Value="{DynamicResource Roboto}"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="Padding" Value="10,5"/>
		
		<Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
		<Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>


		<Style.Resources>
			<SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent"/>
			<SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
			<SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="Transparent" />
		</Style.Resources>
	</Style>

	<!--Tag border-->
	<Style Selector="Border.TagAddBorder">
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="BorderBrush" Value="{StaticResource TagBlue}"/>
		<Setter Property="Background" Value="{StaticResource DarkestNight}"/>
		<Setter Property="CornerRadius" Value="20"/>

		<Setter Property="MinHeight" Value="34"/>
		<Setter Property="Padding" Value="5"/>

	</Style>
	<!--Game search border-->
	<Style Selector="Border.GameAddBorder">
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="BorderBrush" Value="{DynamicResource GalaxyGradient}"/>
		<Setter Property="Background" Value="{StaticResource DarkestNight}"/>
		<Setter Property="CornerRadius" Value="20"/>

		<Setter Property="MinHeight" Value="34"/>
		<Setter Property="Padding" Value="5"/>

	</Style>
</Styles>
