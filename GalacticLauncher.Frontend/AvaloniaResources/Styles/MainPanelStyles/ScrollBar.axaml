<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--Scroll bar-->
	<Style Selector="ScrollBar">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="MinWidth" Value="12"/>
	</Style>

		<Style Selector="ScrollBar /template/ Thumb">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Border Name="ThumbVisual"
							Background="{DynamicResource GalaxyGradient}"
							CornerRadius="6"
							Margin="2"/>
				</ControlTemplate>
			</Setter>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb:pointerover /template/ Border#ThumbVisual">
			<Setter Property="Background" Value="{DynamicResource GalaxyGradient}"/>
		</Style>

		<Style Selector="ScrollBar /template/ Thumb:pressed /template/ Border#ThumbVisual">
			<Setter Property="Background" Value="{DynamicResource GalaxyGradient}"/>
			<Setter Property="Opacity" Value="0.8"/>
		</Style>

		<Style Selector="ScrollBar /template/ RepeatButton">
			<Setter Property="IsVisible" Value="False"/>
		</Style>

		<Style Selector="ScrollBar /template/ Rectangle#TrackRect">
			<Setter Property="Fill" Value="{DynamicResource SideMenuGradient}"/>
			<Setter Property="Opacity" Value="1" />
		</Style>

		<Style Selector="ScrollBar:not(:pointerover) /template/ Rectangle#TrackRect">
			<Setter Property="Fill" Value="{DynamicResource SideMenuGradient}"/>
		</Style>

		<Style Selector="ScrollBar /template/ Track">
			<Setter Property="Opacity" Value="1" />
			<Setter Property="IsVisible" Value="True" />
		</Style>

		<Style Selector="ScrollBar:pointerover /template/ Rectangle#TrackRect">
			<Setter Property="Fill" Value="{DynamicResource SideMenuGradient}" />
		</Style>

		<Style Selector="ScrollBar /template/ Track:pointerover /template/ Rectangle#TrackRect">
			<Setter Property="Fill" Value="{DynamicResource SideMenuGradient}" />
		</Style>

		<Style Selector="ScrollBar /template/ Rectangle#TrackRect">
			<Setter Property="Transitions" Value="{x:Null}" />
		</Style>

	</Styles>