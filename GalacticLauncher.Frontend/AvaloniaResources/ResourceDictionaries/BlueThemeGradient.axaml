<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--Galaxy Gradient Colors-->
	<Color x:Key="GalaxyOceanBlue">#669eff</Color>
	<Color x:Key="GalaxyDeepOcean">#2857ff</Color>
	<Color x:Key="GalaxyUnderWater">#0048ff</Color>

	<Color x:Key="GalaxyPinkiePie">#669eff</Color>

	<!--Galaxy gradient-->
	<LinearGradientBrush x:Key="GalaxyGradient"
						 StartPoint="0%,0%"
						 EndPoint="100%,100%">
		<GradientStop Color="{StaticResource GalaxyOceanBlue}" Offset="0.0"/>
		<GradientStop Color="{StaticResource GalaxyDeepOcean}" Offset="0.5"/>
		<GradientStop Color="{StaticResource GalaxyUnderWater}" Offset="1.0"/>
	</LinearGradientBrush>

</ResourceDictionary>
