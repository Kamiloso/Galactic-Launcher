	</ItemGroup>
	<ItemGroup>
	  <None Remove="AvaloniaResources\Assets\LibraryAssets\search.png" />
	</ItemGroup>
	<ItemGroup>
	  <AvaloniaResource Update="AvaloniaResources\ResourceDictionaries\fonts.axaml">
