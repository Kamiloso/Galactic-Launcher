	  <AvaloniaXaml Remove="AvaloniaResources\Styles\LibraryStyles\searchTextBox.axaml" />
	  <AvaloniaXaml Remove="AvaloniaResources\Styles\MainPanelStyles\ScrollBar.axaml" />
