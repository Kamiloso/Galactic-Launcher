    <AvaloniaResource Include="AvaloniaResources\Assets\SideMenuAssets\account.png" />
    <AvaloniaResource Include="AvaloniaResources\Assets\Fonts\Poppins-Regular.ttf" />
    <AvaloniaResource Include="AvaloniaResources\Assets\Fonts\Rajdhani-Regular.ttf" />
    <AvaloniaResource Include="AvaloniaResources\Assets\Fonts\Rationale-Regular.ttf" />
    <AvaloniaResource Include="AvaloniaResources\Assets\Fonts\Roboto-Regular.ttf" />
    <AvaloniaResource Include="AvaloniaResources\Assets\HomeViewAssets\temp1.jpg" />
    <AvaloniaResource Include="AvaloniaResources\Assets\HomeViewAssets\temp2.jpg" />
    <AvaloniaResource Include="AvaloniaResources\Assets\HomeViewAssets\temp3.jpg" />
    <AvaloniaResource Include="AvaloniaResources\Assets\HomeViewAssets\temp4.jpg" />
