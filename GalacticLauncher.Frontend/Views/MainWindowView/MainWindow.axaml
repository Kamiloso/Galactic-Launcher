<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.MainWindowViewModels"
		xmlns:views="clr-namespace:GalacticLauncher.Frontend.Views.MainWindowView"
        x:Class="GalacticLauncher.Frontend.Views.MainWindowView.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Galactic Launcher"
		MinWidth="1024"
		MinHeight="576"
        WindowStartupLocation="CenterScreen">
	
	<Grid ColumnDefinitions="220, *">
		
		<!--Side Menu-->
		<views:SideMenu x:Name="SideBar" Grid.Column="0" />
		
		<!--Main panel-->
		<Grid Grid.Column="1"
			  Background="{DynamicResource BackgroundGradient}">
			
				<!--Main Panel content-->
				<Border>
					<ContentControl Content="{Binding CurrentPage}" />
				</Border>
		</Grid>
	</Grid>
</Window>