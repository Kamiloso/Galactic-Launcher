<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.LibraryView"
			 xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.Panels"
			 x:DataType="vm:LibraryViewModel"
			 xmlns:btn="clr-namespace:GalacticLauncher.Frontend.ViewModels.Buttons"
			 x:CompileBindings="True">
	
	<!--Library view-->
	<Grid>
		<Grid RowDefinitions="Auto,Auto"
			  Margin="30,20,30,50">
			
			<!--Welcome back!-->
			<Grid ColumnDefinitions="*, Auto" HorizontalAlignment="Stretch" Grid.Row="0">

				<TextBlock Classes="slogan"
						   Text="LIBRARY"
						   HorizontalAlignment="Left"
						   VerticalAlignment="Bottom"
						   Grid.Column="0"/>

				<Button Classes="refreshButton"
						HorizontalAlignment="Right"
						Command="{Binding RefreshPageCommand}"
						Grid.Column="1">

					<PathIcon Data="{StaticResource IconRefresh}"/>
				</Button>

			</Grid>

			<Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto"
				  HorizontalAlignment="Left"
				  VerticalAlignment="Center">

				<!--buttons-->
				<Button Classes="favouriteAll"
						Content="YOUR GAMES"
						Classes.active="{Binding IsYourGamesPage}"
						Command="{Binding ChangeViewCommand}"
						CommandParameter="{x:Static vm:LibraryViewModel+LibraryViewMode.YourGames}"
						Grid.Column="0">
				</Button>
				<Button Classes="favouriteAll"
						Content="FAVOURITES"
						Classes.active="{Binding IsFavoritePage}"
						Command="{Binding ChangeViewCommand}"
						CommandParameter="{x:Static vm:LibraryViewModel+LibraryViewMode.Favorites}"
						Grid.Column="1">
				</Button>
				<Button Classes="favouriteAll"
						Content="FIND NEW GAMES"
						Classes.active="{Binding IsMoreGamesPage}"
						Command="{Binding ChangeViewCommand}"
						CommandParameter="{x:Static vm:LibraryViewModel+LibraryViewMode.MoreGames}"
						Grid.Column="2">
				</Button>

			</Grid>
		</Grid>

		<!--search view-->
		<Border Classes="SearchBorder"
				Padding="20,20,20,30"
				HorizontalAlignment="Right"
				Width="230"
				Margin="30,120,30,30">
			
			<Grid RowDefinitions="40,35,40,35,Auto,*">
				<Grid Grid.Row="0">

					<StackPanel Orientation="Horizontal"
								Spacing="10"
								HorizontalAlignment="Left"
								VerticalAlignment="Center">

						<PathIcon Data="{StaticResource IconSearch}"
							   Height="15"
							   Width="15"
							   Margin="0,0,0,2"/>

						<TextBlock Classes="searchHeader"
								   Text="SEARCH LIBRARY"/>
					</StackPanel>
					
				</Grid>
				
				<Border Grid.Row="1"
						Classes="GameSearchBorder"
						Height="30"
						VerticalAlignment="Center">

					<!--Search games-->
					<TextBox Classes="galaxyTextBox"
							 Text="{Binding SearchGames}"/>
				</Border>

				<Grid Grid.Row="2">
					<StackPanel Orientation="Horizontal"
								Spacing="10"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Margin="0,10,0,0">

						<PathIcon Data="{StaticResource IconSearch}"/>

						<TextBlock Classes="searchHeader"
								   Text="SEARCH TAGS"/>
					</StackPanel>
				</Grid>
				
				<Border Grid.Row="3"
						Classes="TagSearchBorder"
						Height="30"
						Margin="0,0,0,20"
						VerticalAlignment="Center">

					<!--Search tags-->
					<TextBox Classes="galaxyTextBox"
							 Text="{Binding SearchTags, Mode=TwoWay}"/>
				</Border>

				<Panel Grid.Row="4" Margin="0,10,0,10">
					<ItemsControl ItemsSource="{Binding AddedTags}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Classes="tagButton"
										Classes.active="{Binding IsActive}"
										Command="{Binding ToggleTagCommand}">
									<TextBlock Text="{Binding Name}"/>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Panel>

				<Border Grid.Row="5" Classes="TagsBorder" VerticalAlignment="Stretch">
					<Panel>
						<ItemsControl ItemsSource="{Binding FoundTags}" IsVisible="{Binding !HasNoFoundTags}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Button Classes="tagButton"
											Classes.active="{Binding IsActive}"
											Command="{Binding ToggleTagCommand}">
										<TextBlock Text="{Binding Name}"/>
									</Button>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<ContentControl Classes="noFound"
										Tag="NO TAGS FOUND"
										IsVisible="{Binding HasNoFoundTags}"/>
					</Panel>
				</Border>
			</Grid>
		</Border>

		<Border Classes="galaxyBorder"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Margin="30,120,270,30"
				Padding="20,20,20,20">
			
			<!--Games view-->
			<ScrollViewer Classes="ScrollBar"
						  HorizontalScrollBarVisibility="Disabled"
						  VerticalScrollBarVisibility="Auto"
						  Margin="0,0,10,0">

				<WrapPanel HorizontalAlignment="Center"
						   VerticalAlignment="Top"
						   ItemSpacing="15"
						   LineSpacing="15">

					<ItemsControl ItemsSource="{Binding FoundGames}"
										  Background="Transparent">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="3" ColumnSpacing="20" RowSpacing="20" HorizontalAlignment="Center"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="btn:GameButtonViewModel">
								<Button Classes="imageClickable"
										Command="{Binding ShowGameCommand}"
										IsEnabled="{Binding IsGameValid}"
										Tag="{Binding StatusMessage}"
										Background="{DynamicResource MainPanelGradient}">

									<Image Source="{Binding Icon}"
										   IsVisible="{Binding IsGameValid}"/>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					
					<ContentControl Classes="noFound"
									Tag="GAMES NOT FOUND"
									IsVisible="{Binding HasFoundGames}"
									VerticalAlignment="Center"
									HorizontalAlignment="Center"/>
				</WrapPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>
