<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.UsersView"
			 xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.AdminPanels"
			 x:DataType="vm:AdUsersViewModel">
	
		<!--users view-->
		<Border Classes="SearchBorder"
				Padding="20,20,20,30"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Grid.Column="2">

			<Grid RowDefinitions="40,35,*">
				<Grid Grid.Row="0">
					<StackPanel Orientation="Horizontal"
								Spacing="10"
								HorizontalAlignment="Left"
								VerticalAlignment="Center">

						<Image Source="/AvaloniaResources/Assets/Icons/user.png"
							   RenderOptions.BitmapInterpolationMode="HighQuality"
							   Height="15"
							   Width="15"
							   Stretch="Uniform"/>

						<TextBlock Grid.Column="1"
								   Classes="searchHeader"
								   Text="SEARCH USERS"/>
					</StackPanel>
				</Grid>

				<Border Classes="TagAddBorder"
						MinHeight="30"
						VerticalAlignment="Stretch"
						Margin="0,0,0,20"
						Grid.Row="1">

					<TextBox Classes="TagAddTextBox"
							 MaxLength="100"/>
				</Border>
				<Border Grid.Row="3"
						Classes="TagsBorder"
						VerticalAlignment="Stretch">
					<ContentControl Classes="noFound"
									Tag="NO USERS FOUND"/>

				</Border>
			</Grid>
		</Border>
</UserControl>
