<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.GameView"
             xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.Panels"
             x:DataType="vm:GameViewModel">

	<!--Game view-->
	<Grid>
		<!--only the galaxy border for looks-->
		<Border Classes="galaxyBorder"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Margin="45,45,45,45">
		</Border>

		<ScrollViewer Classes="ScrollBar"
					  HorizontalScrollBarVisibility="Disabled"
					  VerticalScrollBarVisibility="Auto">

			<!--Game content-->
			<Border Margin="50,50,50,50"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch">
				<Grid>
					<Grid RowDefinitions="Auto,Auto">
						<!--Banner + icon + title-->
						<Grid Grid.Row="0">
							<Viewbox Stretch="Uniform"
									 Margin="10,10,10,10">

								<Grid HorizontalAlignment="Stretch"
									  VerticalAlignment="Top">

									<!--Banner-->
									<Viewbox Stretch="Uniform"
											 HorizontalAlignment="Stretch"
											 VerticalAlignment="Top">

										<Border Width="1024"
												Height="247"
												CornerRadius="20"
												ClipToBounds="True">

											<!--Banner image-->
											<Image Source="/AvaloniaResources/Assets/Placeholders/banner.png"
												   Stretch="UniformToFill"/>
										</Border>
									</Viewbox>

									<!--Icon -->
									<Grid RowDefinitions="*,*" ColumnDefinitions="Auto,*">
										<Viewbox Grid.Row="1" Grid.Column="0"
												 Stretch="Uniform"
												 HorizontalAlignment="Left"
												 Margin="30,0,0,0">

											<Border Height="196"
													Width="196"
													ClipToBounds="True"
													CornerRadius="0"
													BorderBrush="{DynamicResource GalaxyGradient}"
													BorderThickness="3">

												<!--Icon Image-->
												<Image Source="/AvaloniaResources/Assets/Placeholders/temp3.jpg"
													   Stretch="UniformToFill"/>
											</Border>
										</Viewbox>

										<!--title-->
										<Grid Grid.Row="1" Grid.Column="1" RowDefinitions="*,*"
											  HorizontalAlignment="Stretch">
											<TextBlock Grid.Row="1"
													   Classes="slogan"
													   VerticalAlignment="Center"
													   HorizontalAlignment="Stretch"
													   Margin="20,0,0,0"
													   TextTrimming="CharacterEllipsis"
													   TextWrapping="Wrap"
													   FontSize="30"
													   Text="GAME TITLE LOOOOOOOOOOOOOOOOOOOONG LOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOONG
													   LOOOOOOOOOOOOOOOOOOOOOOOOOOONGggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggggg">
											</TextBlock>
											
										</Grid>
									</Grid>
								</Grid>
                      </Viewbox>
					</Grid>

					<StackPanel Grid.Row="1" Margin="20,20,20,0" Spacing="10">
						<ProgressBar Minimum="0"
								 Maximum="1"
								 Height="6"
								 Value="{Binding DownloadProgress}"
								 IsVisible="{Binding IsDownloadingState}" />

						<StackPanel Orientation="Horizontal" Spacing="10">
							<Button Content="{Binding DownloadButtonText}"
									Command="{Binding DownloadSelectedVersionCommand}"
									IsEnabled="{Binding IsNoInstanceState}" />
							<Button Content="Cancel"
									Command="{Binding CancelDownloadCommand}"
									IsEnabled="{Binding IsDownloadingState}" />
							<Button Content="Play"
									Command="{Binding PlaySelectedVersionCommand}"
									IsEnabled="{Binding IsReadyToPlayState}" />
							<Button Content="Delete"
									Command="{Binding DeleteSelectedVersionCommand}"
									IsEnabled="{Binding IsReadyToPlayState}" />
						</StackPanel>

						<ComboBox ItemsSource="{Binding AvailableVersions}"
									SelectedItem="{Binding SelectedVersion}"
									PlaceholderText="Select version"
									HorizontalAlignment="Left"
									Width="260">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding Caption}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<TextBox Text="{Binding GameDisplayDebugJson}"
									IsReadOnly="True"
									AcceptsReturn="True"
									TextWrapping="Wrap"
									Height="160" />

						<TextBox Text="{Binding SelectedVersionDebugJson}"
									IsReadOnly="True"
									AcceptsReturn="True"
									TextWrapping="Wrap"
									Height="160" />
					</StackPanel>
					</Grid>
				</Grid>
			</Border>

		</ScrollViewer>
	</Grid>
</UserControl>