<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.AllGamesView"
			 xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.AdminPanels"
			 x:DataType="vm:AdGamesViewModel">
	<Grid>
		<!--GAMES HERE-->
		<Border Classes="SearchBorder"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Padding="20,20,20,20"
				Grid.Column="0">

			<!--The games found-->
			<Grid RowDefinitions="30,35,Auto,*,50">

				<StackPanel Grid.Row="0" Orientation="Horizontal"
							Spacing="10"
							HorizontalAlignment="Left"
							VerticalAlignment="Center">

					<Image Source="/AvaloniaResources/Assets/Icons/search.png"
						   RenderOptions.BitmapInterpolationMode="HighQuality"
						   Height="15"
						   Width="15"
						   Stretch="Uniform"/>

					<TextBlock Grid.Column="1"
							   Classes="searchHeader"
							   Text="SEARCH GAMES"/>
				</StackPanel>
				<Border Grid.Row="1"
						Classes="GameAddBorder"
						Height="30"
						Margin="0,0,0,20"
						VerticalAlignment="Center">

					<TextBox Classes="galaxyTextBox"
							 Watermark="Search games..."/>
				</Border>

				<Border Grid.Row="3"
						Classes="GameSearchBorder"
						VerticalAlignment="Stretch">
					<ContentControl Classes="noFound"
									Tag="NO GAMES FOUND"/>
				</Border>

				<!--Buttons to add/edit games-->
				<StackPanel Orientation="Horizontal"
							Spacing="15">
					
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</UserControl>
