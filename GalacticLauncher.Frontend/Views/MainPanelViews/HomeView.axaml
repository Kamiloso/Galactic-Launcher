<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.HomeView"
			 xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.MainPanelViewModels"
			 x:DataType="vm:HomeViewModel"
			 x:CompileBindings="True">


	<ScrollViewer Classes="ScrollBar"
						  HorizontalScrollBarVisibility="Disabled"
						  VerticalScrollBarVisibility="Auto">
		
		<!--Home view-->
		<Border Padding="60,60,60,60">
			<Grid RowDefinitions="Auto,Auto,Auto"
				  HorizontalAlignment="Stretch"
				  VerticalAlignment="Center">

				<!--Welcome back!-->
				<TextBlock Classes="slogan"
						   Grid.Row="0"
						   Text="WELCOME BACK!"
						   HorizontalAlignment="Left"
						   VerticalAlignment="Bottom"/>

				<!--Recommendations-->
				<Viewbox Grid.Row="1"
						 Stretch="Uniform"
						 HorizontalAlignment="Stretch"
						 VerticalAlignment="Top"
						 Margin="0,30,0,0">

					<Grid RowDefinitions="Auto,10,Auto"
						  Width="852"
						  Height="272">

						<!--Recommendation header-->
						<Border Grid.Row="0"
								Classes="galaxyHeader"
								HorizontalAlignment="Left"
								Height="36">
							<TextBlock Classes="homeHeader"
									   Text="RECOMMENDATIONS"
									   HorizontalAlignment="Left"/>
						</Border>

						<!--Recommendations-->
						<Border Grid.Row="2"
								Classes="galaxyBorder"
								Height="220">

						</Border>
					</Grid>
				</Viewbox>

				<!--Recommendations-->
				<Viewbox Grid.Row="2"
						 Stretch="Uniform"
						 HorizontalAlignment="Stretch"
						 VerticalAlignment="Top"
						 Margin="0,30,0,0">

					<Grid RowDefinitions="Auto,10,Auto"
						  Width="852"
						  Height="272">

						<!--Recommendation header-->
						<Border Grid.Row="0"
								Classes="galaxyHeader"
								HorizontalAlignment="Left"
								Height="36">
							<TextBlock Classes="homeHeader"
									   Text="RECOMMENDATIONS"
									   HorizontalAlignment="Left"/>
						</Border>

						<!--Recommendations-->
						<Border Grid.Row="2"
								Classes="galaxyBorder"
								Height="220">

							<UniformGrid Columns="5" Spacing="10">
								<Border Background="{DynamicResource MainPanelGradient}">
									<Image Source="avares://GalacticLauncher.Frontend/AvaloniaResources/Assets/LibraryAssets/search.png"/>
								</Border>
								
							</UniformGrid>
						</Border>
					</Grid>
				</Viewbox>

			</Grid>
		</Border>
	</ScrollViewer>
</UserControl>


