<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:GalacticLauncher.Frontend.ViewModels.AdminViewModels"
		xmlns:views="clr-namespace:GalacticLauncher.Frontend.Views.MainPanelViews"
        x:Class="GalacticLauncher.Frontend.Views.MainPanelViews.GameEditView"
        x:DataType="vm:GameEditViewModel"
        Title="Galactic Launcher - Edit game page"
		MinWidth="8024"
		MinHeight="576"
        WindowStartupLocation="CenterScreen"
		Icon="{StaticResource AppIcon}">

	
</Window>
