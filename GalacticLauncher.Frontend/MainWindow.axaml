<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GalacticLauncher.Frontend"
        x:Class="GalacticLauncher.Frontend.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Galactic Launcher"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

	<Grid RowDefinitions="Auto, *" Margin="20">

		<Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">

			<Button Grid.Column="1"
                    Command="{Binding SendRequestAsync}"
                    Content="WYŚLIJ"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#0078D7"
                    Foreground="White"
                    Padding="30,10"
                    Margin="15,0,0,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Center"/>
		</Grid>

		<TextBox Grid.Row="1"
                 Text="{Binding ResponseJson}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 Watermark="Tutaj pojawi się odpowiedź JSON..."
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 Padding="15"
                 BorderBrush="#333333"/>

	</Grid>
</Window>