{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:27687",
        "Certificate": {
          "Path": "./Keys/release_cert.pfx",
          "Password": "HardCodedPass!123"
        }
      }
    }
